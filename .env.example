# =============================================================================
# .env.example — Copie para .env e preencha com suas credenciais reais
# =============================================================================
# NUNCA versione o arquivo .env com credenciais reais.

# ---------------------------------------------------------------------------
# OpenAI
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-proj-...          # Sua API key do OpenAI playground
OPENAI_MODEL=gpt-4o                  # Modelo a usar (gpt-4o, gpt-4o-mini, etc.)

# ---------------------------------------------------------------------------
# Notion Integration
# ---------------------------------------------------------------------------
# Crie uma integration em: https://www.notion.so/my-integrations
# Compartilhe os databases com a integration (botão "Connect to")
NOTION_TOKEN=secret_...              # Token da sua Notion Integration

# IDs dos databases (pegue da URL da página no Notion):
# Ex: https://www.notion.so/SEU_WORKSPACE/[ID-AQUI]?v=...
NOTION_TASKS_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_AGENDA_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---------------------------------------------------------------------------
# Persistência local
# ---------------------------------------------------------------------------
MEMORY_DB_PATH=memory.db             # Caminho para o SQLite de estado compartilhado

# ---------------------------------------------------------------------------
# Focus Guard
# ---------------------------------------------------------------------------
FOCUS_CHECK_INTERVAL=15              # Intervalo em minutos entre alertas do Focus Guard

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
LOG_FILE=logs/agent_system.log       # Arquivo de log
LOG_LEVEL=INFO                       # DEBUG | INFO | WARNING | ERROR
