# =============================================================================
# .env.example — Copie para .env e preencha com suas credenciais reais.
# No Railway: configure via Dashboard → Variables (NUNCA versione o .env).
# =============================================================================

# --- LLM primário: Azure OpenAI (NEOone — gpt-oss-120b) --------------------
# Azure AI Foundry → seu projeto → Keys and Endpoint
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://<seu-recurso>.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-oss-120b
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# --- LLM fallback: OpenAI público ------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_FALLBACK_MODEL=gpt-3.5-turbo

# --- Linear — obrigatório para o Capture Agent -----------------------------
# API key pessoal: Linear → Settings → API → Personal API keys
LINEAR_API_KEY=
# ID do time onde as issues serão criadas (Settings → Team → General → Team ID)
LINEAR_TEAM_ID=

# --- Redis (Railway provisiona automaticamente) ----------------------------
# Local:   redis://localhost:6379/0
# Railway: redis://default:PASSWORD@redis.railway.internal:6379
REDIS_URL=redis://localhost:6379/0

# --- Telegram (captura inbound → Capture Agent) ----------------------------
TELEGRAM_BOT_TOKEN=
# chat IDs autorizados (comma-separated). Vazio = libera todos (não recomendado).
TELEGRAM_ALLOWED_CHAT_IDS=

# --- GitHub Projects v2 (espelho de tarefas de engenharia) -----------------
# PAT com scopes: project, read:org, repo
GITHUB_TOKEN=
GH_PROJECT_FLOWPAY=1
GH_PROJECT_FLOWOFF=1
GH_PROJECT_NEO=1
GH_PROJECT_FACTORY=1
# Pasta raiz dos org workspaces para `python main.py github discover`
# NEOMELLO_WORKSPACES_ROOT=/Users/seu_usuario/neomello

# --- Focus Guard -----------------------------------------------------------
FOCUS_CHECK_INTERVAL=15            # minutos entre check-ins automáticos

# --- Logging ---------------------------------------------------------------
LOG_FILE=./logs/agent_system.log
LOG_LEVEL=INFO                     # DEBUG | INFO | WARNING | ERROR

# --- Notion (ainda lido pelo config.py — pode ficar vazio se não usar) ------
NOTION_TOKEN=
NOTION_DB_PROJETOS=
NOTION_DB_TAREFAS=
NOTION_DB_DECISOES=
NOTION_DB_WORKLOG=
NOTION_DB_INTEGRATIONS=

# --- LLM local opcional (Docker Model Runner, apenas dev local) ------------
# LOCAL_MODEL_ENABLED=false
# LOCAL_MODEL_NAME=docker.io/ai/gemma3:4B-F16
# LOCAL_MODEL_BASE_URL=http://localhost:12434/engines/llama.cpp/v1
